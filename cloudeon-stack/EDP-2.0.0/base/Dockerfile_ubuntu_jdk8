FROM ubuntu:22.04
SHELL ["/bin/bash", "-c"]

RUN ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && echo 'Asia/Shanghai' >/etc/timezone

ENV TZ=Asia/Shanghai  \
    FREEMARKER_GENERATOR_CLI_HOME=/opt/freemarker-generator-cli
ENV PATH=$PATH:$FREEMARKER_GENERATOR_CLI_HOME/bin

# Install all packages in one step to reduce layer size and avoid multiple source updates
# Use different mirrors based on architecture for better reliability
RUN if [ "$(uname -m)" = "x86_64" ]; then \
        sed -i 's|http://archive.ubuntu.com/ubuntu/|http://mirrors.aliyun.com/ubuntu/|g' /etc/apt/sources.list; \
    else \
        sed -i 's|http://ports.ubuntu.com/ubuntu-ports/|http://mirrors.ustc.edu.cn/ubuntu-ports/|g' /etc/apt/sources.list; \
    fi \
    && apt-get update && apt-get install -y \
    curl \
    wget \
    net-tools \
    vim \
    perl \
    debianutils \
    netcat \
    zip \
    unzip \
    lsof \
    bc \
    hostname \
    cron \
    openjdk-8-jdk \
    mysql-client \
    && rm -rf /var/lib/apt/lists/*

ADD freemarker-generator-cli-0.2.0-SNAPSHOT-app.tar.gz /opt/
RUN mv /opt/freemarker-generator-cli-* /opt/freemarker-generator-cli

# setup jmx exporter
RUN wget --no-check-certificate https://repo1.maven.org/maven2/io/prometheus/jmx/jmx_prometheus_javaagent/0.20.0/jmx_prometheus_javaagent-0.20.0.jar  \
    && mkdir -p /opt/jmx_exporter  \
    && mv jmx_prometheus_javaagent-0.20.0.jar /opt/jmx_exporter/jmx_prometheus_javaagent.jar

# Set JAVA_HOME dynamically for multi-platform support
RUN JAVA_HOME_PATH=$(readlink -f /usr/bin/javac | sed "s:/bin/javac::") \
    && echo "export JAVA_HOME=$JAVA_HOME_PATH" >> /etc/environment \
    && echo "export PATH=\$JAVA_HOME/bin:\$PATH" >> /etc/environment \
    && echo "Detected JAVA_HOME: $JAVA_HOME_PATH"

# Set fallback JAVA_HOME for ENV (will be overridden by /etc/environment)
ENV JAVA_HOME=/usr/lib/jvm/default-java
ENV PATH=$JAVA_HOME/bin:$PATH

# Create symlink for consistent access
RUN JAVA_HOME_PATH=$(readlink -f /usr/bin/javac | sed "s:/bin/javac::") \
    && ln -sf $JAVA_HOME_PATH /usr/lib/jvm/default-java
